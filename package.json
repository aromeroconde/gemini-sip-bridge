  "description": "Bridge between SIP (drachtio/Zadarma) and Google Gemini Live API",
  "main": "index.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --watch lib/**/*.ts,index.ts,.env index.ts",
